---
import Layout from '../../layouts/Layout.astro';
import { tools, categories } from '../../data/tools';

// 只生成同分类、高搜索意图的对比页，避免 sitemap 被低质量跨品类模板页稀释
export function getStaticPaths() {
  const comparableCategories = ['llm', 'code', 'image', 'video', 'audio', 'search', 'docs'];
  const paths = [];
  for (let i = 0; i < tools.length; i++) {
    for (let j = i + 1; j < tools.length; j++) {
      if (tools[i].category !== tools[j].category) continue;
      if (!comparableCategories.includes(tools[i].category)) continue;
      paths.push({ params: { tools: `${tools[i].id}-vs-${tools[j].id}` } });
    }
  }
  return paths;
}

// 从 URL 参数获取两个工具 ID
const { tools: toolsParam } = Astro.params;
const ids = toolsParam?.split('-vs-') || [];

const toolA = tools.find(t => t.id === ids[0]);
const toolB = tools.find(t => t.id === ids[1]);

// 获取所有工具用于选择器；前端仍允许用户选择任意组合，未生成的组合会自然 404/回首页
const allTools = [...tools].sort((a, b) => a.name.localeCompare(b.name));

// 如果没有有效参数，重定向
if (!toolA || !toolB) {
  return Astro.redirect('/');
}

const categoryA = categories.find(c => c.id === toolA.category);
const categoryB = categories.find(c => c.id === toolB.category);
const compareTitle = `${toolA.name} vs ${toolB.name}：功能、定价、优缺点对比 | BigModels.top`;
const compareDescription = `${toolA.name} 和 ${toolB.name} 哪个更适合你？对比评分、定价、核心功能、优缺点和适用人群，帮你快速选择合适的 AI 工具。`;
const toolAUrl = toolA.affiliateUrl || toolA.url;
const toolBUrl = toolB.affiliateUrl || toolB.url;

function renderStars(rating: number) {
  const full = Math.floor(rating);
  const half = rating % 1 >= 0.5;
  return '★'.repeat(full) + (half ? '½' : '') + '☆'.repeat(5 - full - (half ? 1 : 0));
}

function getRecommendation() {
  if (toolA.rating > toolB.rating) return `${toolA.name} 更适合优先体验，评分更高。`;
  if (toolB.rating > toolA.rating) return `${toolB.name} 更适合优先体验，评分更高。`;
  return `${toolA.name} 和 ${toolB.name} 评分接近，建议按你的使用场景和预算选择。`;
}

const jsonLd = {
  "@context": "https://schema.org",
  "@type": "Article",
  "headline": `${toolA.name} vs ${toolB.name} AI 工具对比`,
  "description": compareDescription,
  "url": `https://bigmodels.top/compare/${toolA.id}-vs-${toolB.id}/`,
  "author": {
    "@type": "Organization",
    "name": "BigModels.top",
    "url": "https://bigmodels.top"
  },
  "publisher": {
    "@type": "Organization",
    "name": "BigModels.top",
    "url": "https://bigmodels.top"
  },
  "about": [
    { "@type": "SoftwareApplication", "name": toolA.name, "applicationCategory": categoryA?.name || 'AI Tool' },
    { "@type": "SoftwareApplication", "name": toolB.name, "applicationCategory": categoryB?.name || 'AI Tool' }
  ]
};
---

<Layout title={compareTitle} description={compareDescription} keywords={`${toolA.name} vs ${toolB.name},${toolA.name} 对比 ${toolB.name},AI工具对比,${categoryA?.name || ''}`}>
  <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} slot="head" />
  <div class="max-w-5xl mx-auto">
    <!-- 页面标题 -->
    <div class="text-center mb-8">
      <h1 class="text-3xl font-bold text-gray-900 mb-2">{toolA.name} vs {toolB.name}</h1>
      <p class="text-gray-500">对比评分、定价、核心能力、优缺点和适用人群，快速选择合适的 AI 工具</p>
    </div>

    <!-- 工具选择器 -->
    <div class="bg-white rounded-2xl border border-gray-200 p-6 mb-8 shadow-sm">
      <div class="flex flex-col md:flex-row items-center justify-center gap-4">
        <select id="selectA" class="flex-1 max-w-xs px-4 py-2 rounded-xl border border-gray-200 bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-400">
          <option value="">选择工具 A...</option>
          {allTools.map(t => (
            <option value={t.id} selected={t.id === toolA.id}>{t.name}</option>
          ))}
        </select>
        <span class="text-2xl font-bold text-brand-500">VS</span>
        <select id="selectB" class="flex-1 max-w-xs px-4 py-2 rounded-xl border border-gray-200 bg-white text-gray-900 focus:outline-none focus:ring-2 focus:ring-brand-400">
          <option value="">选择工具 B...</option>
          {allTools.map(t => (
            <option value={t.id} selected={t.id === toolB.id}>{t.name}</option>
          ))}
        </select>
        <button id="compareBtn" class="bg-brand-500 hover:bg-brand-600 text-white px-6 py-2 rounded-xl font-medium transition-colors">
          对比
        </button>
      </div>
      <p class="text-xs text-gray-400 text-center mt-3">优先收录同类工具对比，跨品类组合建议从工具详情页分别查看。</p>
    </div>

    <!-- 推荐结论 -->
    <div class="bg-gradient-to-r from-brand-50 to-indigo-50 border border-brand-100 rounded-2xl p-6 mb-8">
      <h2 class="text-xl font-bold text-gray-900 mb-2">怎么选？</h2>
      <p class="text-gray-700">{getRecommendation()}</p>
    </div>

    <!-- 对比结果 -->
    <div class="grid grid-cols-1 md:grid-cols-2 gap-6 mb-8">
      <!-- 工具 A -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-brand-500 to-accent-500 p-6 text-white">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-2xl font-bold mb-1">{toolA.name}</h2>
              <p class="text-white/80 text-sm">{categoryA?.icon} {categoryA?.name}</p>
            </div>
            <div class="text-right shrink-0">
              <div class="text-3xl font-black">{toolA.rating.toFixed(1)}</div>
              <div class="text-white/70 text-xs">用户评分</div>
            </div>
          </div>
        </div>
        <div class="p-6 space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-gray-500 text-sm">评分</span>
            <span class="text-amber-500 font-semibold">{renderStars(toolA.rating)} {toolA.rating.toFixed(1)}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500 text-sm">定价</span>
            <span class="font-medium text-gray-900">{toolA.pricing}</span>
          </div>
          <div>
            <h3 class="text-gray-500 text-sm mb-2">核心功能</h3>
            <ul class="space-y-1">
              {toolA.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-gray-700">
                  <span class="text-brand-500 mt-0.5">•</span>
                  {f}
                </li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-gray-500 text-sm mb-2">✅ 优点</h3>
            <ul class="space-y-1">
              {toolA.pros.map(p => (
                <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-green-500 mt-0.5">✓</span>{p}</li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-gray-500 text-sm mb-2">❌ 缺点</h3>
            <ul class="space-y-1">
              {toolA.cons.map(c => (
                <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-red-400 mt-0.5">✗</span>{c}</li>
              ))}
            </ul>
          </div>
          <div class="pt-2 border-t border-gray-100">
            <p class="text-xs text-gray-500 mb-1">适用人群</p>
            <p class="text-sm text-gray-700">{toolA.targetAudience}</p>
          </div>
          <a href={toolA.affiliateUrl || toolA.url} target="_blank" rel="noopener noreferrer"
            class="block text-center bg-brand-500 hover:bg-brand-600 text-white py-2.5 rounded-xl font-medium transition-colors">
            访问 {toolA.name} →
          </a>
        </div>
      </div>

      <!-- 工具 B -->
      <div class="bg-white rounded-2xl border border-gray-200 shadow-sm overflow-hidden">
        <div class="bg-gradient-to-r from-accent-500 to-purple-600 p-6 text-white">
          <div class="flex items-start justify-between gap-4">
            <div>
              <h2 class="text-2xl font-bold mb-1">{toolB.name}</h2>
              <p class="text-white/80 text-sm">{categoryB?.icon} {categoryB?.name}</p>
            </div>
            <div class="text-right shrink-0">
              <div class="text-3xl font-black">{toolB.rating.toFixed(1)}</div>
              <div class="text-white/70 text-xs">用户评分</div>
            </div>
          </div>
        </div>
        <div class="p-6 space-y-4">
          <div class="flex items-center justify-between">
            <span class="text-gray-500 text-sm">评分</span>
            <span class="text-amber-500 font-semibold">{renderStars(toolB.rating)} {toolB.rating.toFixed(1)}</span>
          </div>
          <div class="flex items-center justify-between">
            <span class="text-gray-500 text-sm">定价</span>
            <span class="font-medium text-gray-900">{toolB.pricing}</span>
          </div>
          <div>
            <h3 class="text-gray-500 text-sm mb-2">核心功能</h3>
            <ul class="space-y-1">
              {toolB.features.map(f => (
                <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-brand-500 mt-0.5">•</span>{f}</li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-gray-500 text-sm mb-2">✅ 优点</h3>
            <ul class="space-y-1">
              {toolB.pros.map(p => (
                <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-green-500 mt-0.5">✓</span>{p}</li>
              ))}
            </ul>
          </div>
          <div>
            <h3 class="text-gray-500 text-sm mb-2">❌ 缺点</h3>
            <ul class="space-y-1">
              {toolB.cons.map(c => (
                <li class="flex items-start gap-2 text-sm text-gray-700"><span class="text-red-400 mt-0.5">✗</span>{c}</li>
              ))}
            </ul>
          </div>
          <div class="pt-2 border-t border-gray-100">
            <p class="text-xs text-gray-500 mb-1">适用人群</p>
            <p class="text-sm text-gray-700">{toolB.targetAudience}</p>
          </div>
          <a href={toolB.affiliateUrl || toolB.url} target="_blank" rel="noopener noreferrer"
            class="block text-center bg-brand-500 hover:bg-brand-600 text-white py-2.5 rounded-xl font-medium transition-colors">
            访问 {toolB.name} →
          </a>
        </div>
      </div>
    </div>

    <!-- 返回首页 -->
    <div class="text-center">
      <a href="/" class="inline-flex items-center gap-2 text-brand-500 hover:text-brand-600 font-medium">
        ← 返回首页
      </a>
    </div>
  </div>
</Layout>

<script>
  const selectA = document.getElementById('selectA') as HTMLSelectElement;
  const selectB = document.getElementById('selectB') as HTMLSelectElement;
  const compareBtn = document.getElementById('compareBtn') as HTMLButtonElement;

  compareBtn?.addEventListener('click', () => {
    const a = selectA.value;
    const b = selectB.value;
    if (a && b && a !== b) {
      window.location.href = `/compare/${a}-vs-${b}`;
    }
  });
</script>

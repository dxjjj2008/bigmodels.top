---
import Layout from '../layouts/Layout.astro';
import { categories, tools } from '../data/tools';

const toolCount = tools.length;
const categoryCount = categories.length;
const homeDescription = `精选 ${toolCount}+ AI 工具，覆盖大语言模型、AI编程、图像生成、视频生成、AI搜索与效率工具，提供评分、定价、优缺点、适用人群和工具对比。`;
const homeKeywords = 'AI工具导航,AI工具评测,ChatGPT,Claude,Cursor,Midjourney,AI编程工具,AI图像生成,AI搜索';
const homeJsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    "name": "BigModels.top",
    "url": "https://bigmodels.top",
    "description": homeDescription,
    "potentialAction": {
      "@type": "SearchAction",
      "target": "https://bigmodels.top/?q={search_term_string}",
      "query-input": "required name=search_term_string"
    }
  },
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "name": "BigModels.top",
    "url": "https://bigmodels.top",
    "description": "AI 工具导航与评测平台"
  }
];

const pricingMap: Record<string, string> = {
  '免费': 'bg-green-100 text-green-700',
  '付费': 'bg-red-100 text-red-700',
  '免费+订阅': 'bg-amber-100 text-amber-700',
  '订阅': 'bg-orange-100 text-orange-700',
};

function getPricingClass(pricing: string) {
  return pricingMap[pricing] || 'bg-gray-100 text-gray-700';
}
---

<Layout title="BigModels.top - 2026 AI工具导航与评测：ChatGPT、Claude、Cursor、Midjourney" description={homeDescription} keywords={homeKeywords}>
  <script type="application/ld+json" set:html={JSON.stringify(homeJsonLd)} slot="head" />
  <!-- Hero Section -->
  <section class="text-center py-16">
    <h1 class="text-5xl font-bold text-gray-900 mb-4">
      🧠 BigModels.top
    </h1>
    <p class="text-xl text-gray-600 mb-8 max-w-2xl mx-auto">
      发现并探索最优秀的 AI 工具，一站式导航平台
    </p>

    <!-- 搜索框 -->
    <div class="max-w-xl mx-auto mb-8 relative">
      <input
        type="text"
        id="searchInput"
        placeholder="搜索 AI 工具..."
        class="w-full px-5 py-3 pl-12 text-lg rounded-xl border border-gray-200 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-brand-400 transition-all"
      />
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl">🔍</span>
      <!-- 搜索结果下拉 -->
      <div id="searchResults" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl border border-gray-200 shadow-lg overflow-hidden hidden z-50 max-h-80 overflow-y-auto">
      </div>
    </div>

    <div class="flex items-center justify-center gap-4 text-gray-500">
      <span class="bg-brand-100 text-brand-600 px-4 py-1 rounded-full text-sm font-medium">
        {toolCount} 个工具
      </span>
      <span class="bg-green-100 text-green-700 px-4 py-1 rounded-full text-sm font-medium">
        {categoryCount} 个分类
      </span>
    </div>
  </section>

  <!-- MiniMax Token Plan 推广横幅 -->
  <section class="mb-8 max-w-6xl mx-auto">
    <a
      href="https://platform.minimaxi.com/subscribe/token-plan?code=INTFeFx6kr&source=link"
      target="_blank"
      rel="noopener noreferrer"
      class="block bg-gradient-to-r from-[#6366F1] to-[#8B5CF6] rounded-2xl p-5 text-white shadow-lg hover:shadow-xl hover:scale-[1.01] transition-all relative overflow-hidden"
    >
      <div class="absolute top-0 right-0 w-32 h-32 bg-white/10 rounded-full -translate-y-1/2 translate-x-1/2"></div>
      <div class="absolute bottom-0 left-0 w-24 h-24 bg-white/10 rounded-full translate-y-1/2 -translate-x-1/2"></div>
      <div class="relative z-10">
        <div class="flex items-center gap-2 mb-2">
          <span class="text-2xl">🚀</span>
          <span class="font-bold text-lg">MiniMax Token Plan 惊喜上线！</span>
        </div>
        <p class="text-white/90 text-sm mb-3 leading-relaxed">
          新增语音、音乐、视频和图片生成权益。邀请好友享双重好礼，助力开发体验！<br/>
          好友立享 <strong>9折 专属优惠</strong> + Builder 权益，你赢返利 + 社区特权！
        </p>
        <div class="inline-flex items-center gap-2 bg-white/20 hover:bg-white/30 px-4 py-2 rounded-full text-sm font-medium transition-colors">
          <span>👉 立即参与</span>
          <svg class="w-4 h-4" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 7l5 5m0 0l-5 5m5-5H6"/></svg>
        </div>
      </div>
    </a>
  </section>

  <!-- 分类导航 -->
  <section class="mb-12">
    <h2 class="text-2xl font-bold text-gray-900 mb-6">📂 按分类浏览</h2>
    <div class="grid grid-cols-2 md:grid-cols-4 lg:grid-cols-8 gap-3">
      {categories.map((category) => {
        const count = tools.filter(t => t.category === category.id).length;
        return (
          <a
            href={`/category/${category.id}`}
            class="group bg-white rounded-xl p-3 border border-gray-200 hover:border-brand-500 hover:shadow-md transition-all text-center"
          >
            <div class="text-3xl mb-1">
              {category.icon}
            </div>
            <h3 class="font-semibold text-gray-900 group-hover:text-brand-600 transition-colors text-sm">
              {category.name}
            </h3>
            <p class="text-xs text-gray-500">{count} 个</p>
          </a>
        );
      })}
    </div>
  </section>

  <!-- 热门工具 -->
  <section>
    <h2 class="text-2xl font-bold text-gray-900 mb-6">🔥 热门工具</h2>
    <div id="featuredTools" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
      {[...tools].sort((a, b) => b.commissionRate * b.rating - a.commissionRate * a.rating).slice(0, 8).map((tool) => (
        <a
          href={`/tool/${tool.id}`}
          data-name={tool.name}
          data-desc={tool.description}
          data-tags={tool.tags.join(',')}
          data-category={tool.category}
          class="tool-card group bg-white rounded-xl p-5 border border-gray-200 hover:border-brand-500 hover:shadow-md transition-all"
        >
          <div class="flex items-start justify-between mb-3">
            <h3 class="font-bold text-lg text-gray-900 group-hover:text-brand-600 transition-colors">
              {tool.name}
            </h3>
            <span class="flex items-center gap-1 text-sm font-medium text-amber-500">
              ⭐ {tool.rating.toFixed(1)}
            </span>
          </div>
          <p class="text-gray-600 text-sm line-clamp-2">{tool.description}</p>
          <div class="flex items-center gap-2 mt-3 flex-wrap">
            <span class="text-xs bg-brand-100 text-brand-600 px-2 py-0.5 rounded">
              {categories.find(c => c.id === tool.category)?.name}
            </span>
            <span class={`text-xs px-2 py-0.5 rounded ${getPricingClass(tool.pricing)}`}>{tool.pricing}</span>
          </div>
          {tool.affiliateUrl && (
            <a
              href={tool.affiliateUrl}
              target="_blank"
              rel="noopener noreferrer"
              onClick={(e) => e.stopPropagation()}
              class="mt-3 inline-flex items-center gap-1 bg-brand-500 hover:bg-brand-600 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition-colors"
            >
              🚀 立即使用 →
            </a>
          )}
        </a>
      ))}
    </div>

    <!-- 全部工具 -->
    <div class="mt-8">
      <h2 class="text-2xl font-bold text-gray-900 mb-6">📋 全部工具</h2>
      <div id="allTools" class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-4">
        {tools.map((tool) => {
          return (
          <a
            href={`/tool/${tool.id}`}
            data-name={tool.name}
            data-desc={tool.description}
            data-tags={tool.tags.join(',')}
            data-category={tool.category}
            class="tool-card group bg-white rounded-xl p-5 border border-gray-200 hover:border-brand-500 hover:shadow-md transition-all flex flex-col"
          >
            <div class="flex items-start justify-between mb-3">
              <h3 class="font-bold text-lg text-gray-900 group-hover:text-brand-600 transition-colors">
                {tool.name}
              </h3>
              <span class="flex items-center gap-1 text-sm font-medium text-amber-500">
                ⭐ {tool.rating.toFixed(1)}
              </span>
            </div>
            <p class="text-gray-600 text-sm line-clamp-2 flex-1">{tool.description}</p>
            <div class="flex items-center gap-2 mt-3 flex-wrap">
              <span class="text-xs bg-brand-100 text-brand-600 px-2 py-0.5 rounded">
                {categories.find(c => c.id === tool.category)?.name}
              </span>
              <span class={`text-xs px-2 py-0.5 rounded ${getPricingClass(tool.pricing)}`}>{tool.pricing}</span>
            </div>
            {tool.affiliateUrl && (
              <a
                href={tool.affiliateUrl}
                target="_blank"
                rel="noopener noreferrer"
                onClick={(e) => e.stopPropagation()}
                class="mt-3 inline-flex items-center gap-1 bg-brand-500 hover:bg-brand-600 text-white px-3 py-1.5 rounded-lg text-xs font-medium transition-colors"
              >
                🚀 立即使用 →
              </a>
            )}
          </a>
          );
        })}
      </div>
    </div>
  </section>
</Layout>

<script>
  // 搜索功能
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const searchResults = document.getElementById('searchResults');
  const allToolCards = document.querySelectorAll<HTMLElement>('.tool-card');

  // 所有工具数据
  const toolsData = Array.from(allToolCards).map(card => ({
    name: card.dataset.name || '',
    desc: card.dataset.desc || '',
    tags: card.dataset.tags || '',
    category: card.dataset.category || '',
    href: card.getAttribute('href') || '',
  }));

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.trim().toLowerCase();

    if (!query) {
      searchResults!.classList.add('hidden');
      return;
    }

    const matched = toolsData.filter(t =>
      t.name.toLowerCase().includes(query) ||
      t.desc.toLowerCase().includes(query) ||
      t.tags.toLowerCase().includes(query)
    );

    if (matched.length === 0) {
      searchResults!.innerHTML = `
        <div class="px-4 py-3 text-gray-500 text-sm">未找到匹配的工具，试试更通用的关键词</div>
        <div class="px-4 py-2 border-t border-gray-100">
          <p class="text-xs text-gray-400 mb-2">🔥 热门工具</p>
          <div class="grid grid-cols-2 gap-1">
            <a href="/tool/chatgpt" class="text-xs text-brand-600 hover:text-brand-700 py-1">ChatGPT</a>
            <a href="/tool/claude" class="text-xs text-brand-600 hover:text-brand-700 py-1">Claude</a>
            <a href="/tool/midjourney" class="text-xs text-brand-600 hover:text-brand-700 py-1">Midjourney</a>
            <a href="/tool/gemini" class="text-xs text-brand-600 hover:text-brand-700 py-1">Gemini</a>
          </div>
        </div>`;
    } else {
      searchResults!.innerHTML = matched.slice(0, 8).map(t => `
        <a href="${t.href}" class="flex items-center gap-3 px-4 py-3 hover:bg-brand-50 transition-colors border-b border-gray-100 last:border-0">
          <span class="font-medium text-gray-900 text-sm">${t.name}</span>
          <span class="text-xs text-gray-500 truncate flex-1">${t.desc.slice(0, 50)}...</span>
        </a>
      `).join('');
    }

    searchResults!.classList.remove('hidden');
  });

  // 点击其他地方关闭搜索结果
  document.addEventListener('click', (e) => {
    if (!searchInput?.contains(e.target as Node) && !searchResults?.contains(e.target as Node)) {
      searchResults?.classList.add('hidden');
    }
  });
</script>

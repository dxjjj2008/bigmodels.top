---
import Layout from '../layouts/Layout.astro';
import { tools } from '../data/tools';

const featured = [...tools].sort((a, b) => b.commissionRate * b.rating - a.commissionRate * a.rating).slice(0, 6);
---

<Layout title="页面未找到 - BigModels.top">
  <div class="min-h-[60vh] flex flex-col items-center justify-center text-center py-16">
    <!-- 404 大字 -->
    <div class="text-9xl font-black text-brand-500/20 mb-4 select-none">404</div>
    <h1 class="text-3xl font-bold text-gray-900 mb-3">页面未找到</h1>
    <p class="text-gray-500 mb-8 max-w-md">抱歉，您访问的页面不存在或已被移除。</p>

    <!-- 搜索框 -->
    <div class="w-full max-w-lg mx-auto mb-8 relative">
      <input
        type="text"
        id="searchInput"
        placeholder="搜索 AI 工具..."
        class="w-full px-5 py-3 pl-12 text-lg rounded-xl border border-gray-200 bg-white shadow-sm focus:outline-none focus:ring-2 focus:ring-brand-400 focus:border-brand-400 transition-all"
      />
      <span class="absolute left-4 top-1/2 -translate-y-1/2 text-gray-400 text-xl">🔍</span>
      <div id="searchResults" class="absolute top-full left-0 right-0 mt-2 bg-white rounded-xl border border-gray-200 shadow-lg overflow-hidden hidden z-50 max-h-80 overflow-y-auto"></div>
    </div>

    <!-- 返回首页 -->
    <a
      href="/"
      class="inline-flex items-center gap-2 bg-brand-500 hover:bg-brand-600 text-white px-6 py-3 rounded-xl font-medium transition-colors shadow-sm"
    >
      ← 返回首页
    </a>

    <!-- 热门工具推荐 -->
    <div class="mt-16 w-full max-w-3xl">
      <h2 class="text-xl font-bold text-gray-900 mb-4">🔥 热门工具</h2>
      <div class="grid grid-cols-2 md:grid-cols-3 gap-3">
        {featured.map((tool) => (
          <a
            href={`/tool/${tool.id}`}
            class="bg-white rounded-xl p-4 border border-gray-200 hover:border-brand-500 hover:shadow-md transition-all text-left"
          >
            <h3 class="font-semibold text-gray-900 text-sm mb-1">{tool.name}</h3>
            <p class="text-xs text-gray-500 line-clamp-2">{tool.description.slice(0, 60)}...</p>
          </a>
        ))}
      </div>
    </div>
  </div>
</Layout>

<script>
  const searchInput = document.getElementById('searchInput') as HTMLInputElement;
  const searchResults = document.getElementById('searchResults');
  const toolCards = document.querySelectorAll<HTMLElement>('a[href^="/tool/"]');
  const toolsData = Array.from(toolCards).map(card => ({
    name: card.querySelector('h3')?.textContent || '',
    href: card.getAttribute('href') || '',
  }));

  searchInput?.addEventListener('input', (e) => {
    const query = (e.target as HTMLInputElement).value.trim().toLowerCase();
    if (!query) { searchResults!.classList.add('hidden'); return; }
    const matched = toolsData.filter(t => t.name.toLowerCase().includes(query));
    if (matched.length === 0) {
      searchResults!.innerHTML = '<div class="px-4 py-3 text-gray-500 text-sm">未找到匹配的工具，试试更通用的关键词</div>';
    } else {
      searchResults!.innerHTML = matched.slice(0, 6).map(t =>
        `<a href="${t.href}" class="flex items-center gap-3 px-4 py-3 hover:bg-brand-50 transition-colors border-b border-gray-100 last:border-0">
          <span class="font-medium text-gray-900 text-sm">${t.name}</span>
        </a>`
      ).join('');
    }
    searchResults!.classList.remove('hidden');
  });

  document.addEventListener('click', (e) => {
    if (!searchResults?.contains(e.target as Node) && e.target !== searchInput) {
      searchResults!.classList.add('hidden');
    }
  });
</script>
